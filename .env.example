# ============================================================
# LibreChat Environment Variables for Railway Deployment
# ============================================================
# Use this as reference when filling Railway's env var form.
# NEVER commit a .env file with real secrets.
# ============================================================

# --- Quatarly unified API key (replaces raw Anthropic key) ---
# Get yours from the Quatarly dashboard.
ANTHROPIC_API_KEY=qua-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Quatarly reverse proxy for native Anthropic endpoint ---
# Routes LibreChat's built-in Anthropic client through Quatarly.
ANTHROPIC_REVERSE_PROXY=https://api.quatarly.cloud

# --- MongoDB ---
# Railway auto-generates this — leave blank in the form.
MONGODB_URI=

# --- JWT Secrets (pre-generated, 32-char alphanumeric) ---
JWT_SECRET=JxjtUvXUQoNqj0As8lgzZvvblHGtGUbY
JWT_REFRESH_SECRET=so13wUJoQnrqJHwbXJeE5e2Wvcu56sa1

# --- Registration / Auth ---
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# --- App Config ---
CONFIG_PATH=/app/librechat.yaml
NODE_ENV=production
HOST=0.0.0.0
PORT=3080
