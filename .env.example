# ============================================================
# LibreChat Environment Variables for Railway Deployment
# ============================================================
# Copy this file as reference when filling in Railway's
# "Deploy from Template" environment variable form.
# NEVER commit a .env file with real secrets.
# ============================================================

# --- Anthropic ---
# Paste your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MongoDB ---
# Railway auto-generates this when you add a MongoDB plugin/service.
# Leave blank in the form — Railway will inject it automatically.
MONGODB_URI=

# --- JWT Secrets (pre-generated, 32-char alphanumeric) ---
JWT_SECRET=JxjtUvXUQoNqj0As8lgzZvvblHGtGUbY
JWT_REFRESH_SECRET=so13wUJoQnrqJHwbXJeE5e2Wvcu56sa1

# --- Registration / Auth ---
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# --- App Config ---
# Points to the librechat.yaml committed in this repo
CONFIG_PATH=/app/librechat.yaml
NODE_ENV=production
HOST=0.0.0.0
PORT=3080
